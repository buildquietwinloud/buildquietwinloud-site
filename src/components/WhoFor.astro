---

<section id="guides" class="relative w-full bg-paper-dim px-6 py-24 dark:bg-ink/60 sm:px-10 sm:py-32 lg:px-16 xl:px-24 2xl:px-32">
  <div class="mx-auto grid max-w-[1680px] grid-cols-12 gap-6">
    <div class="col-span-12 sm:col-span-3">
      <span class="eyebrow flex items-center gap-3 reveal-up" data-who-eyebrow>
        <span class="inline-block h-px w-10 bg-rust"></span>
        Who this is for
      </span>
    </div>
    <div class="col-span-12 sm:col-span-9">
      <p class="font-editorial text-[clamp(2rem,4.5vw,3.6rem)] leading-[1.05] tracking-[-0.02em] text-ink dark:text-paper reveal-up" data-who-line>
        You, if you're trying to use AI to ship something
        and not just chat with it.
      </p>
      <p class="mt-8 max-w-3xl text-lg leading-relaxed text-ink-dim dark:text-paper/80 reveal-up" data-who-body>
        Solo founder, agency operator, someone who opened ChatGPT
        last month &mdash; doesn't matter. If you're bilingual, even better.
        If you're a beginner, especially welcome.
      </p>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const els = document.querySelectorAll<HTMLElement>("[data-who-eyebrow], [data-who-line], [data-who-body]");

  if (!reduce) {
    els.forEach((el, i) => {
      gsap.fromTo(el, { opacity: 0, y: 28 }, {
        opacity: 1, y: 0, duration: 0.95, delay: i * 0.08, ease: "expo.out", immediateRender: false,
        scrollTrigger: { trigger: el, start: "top 88%" },
      });
    });
  }
</script>
