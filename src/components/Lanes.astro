---
const lanes = [
  {
    n: "01",
    title: "The weekly letter",
    status: "Live now",
    body: "What I built that week, the configs, the actual cost numbers. The good and the broken.",
  },
  {
    n: "02",
    title: "Tool reviews",
    status: "Live now",
    body: "What I run, what I dropped after a month, what I haven't touched and why.",
  },
  {
    n: "03",
    title: "Free starter guides",
    status: "Soon",
    body: "AI for people who didn't go to school for this. No gatekeeping, no jargon flex.",
  },
  {
    n: "04",
    title: "1:1 build calls",
    status: "Coming",
    body: "Stuck on something? You'll be able to grab time on my calendar. Probably Q3.",
  },
  {
    n: "05",
    title: "A builder space",
    status: "Maybe",
    body: "If enough of you show up, we open a Discord. If not, no harm done.",
  },
];
---

<section id="letter" class="relative w-full px-6 py-24 sm:px-10 sm:py-32 lg:px-16 xl:px-24 2xl:px-32">
  <div class="mx-auto max-w-[1680px]">
    <div class="flex items-end justify-between border-b border-rule pb-6 dark:border-paper/15">
      <span class="eyebrow flex items-center gap-3 reveal-up" data-lanes-eyebrow>
        <span class="inline-block h-px w-10 bg-rust"></span>
        What's here
      </span>
      <span class="hidden font-mono text-[0.7rem] uppercase tracking-[0.22em] text-ink-faint sm:inline-block">/ 05 lanes</span>
    </div>

    <ul class="mt-2">
      {lanes.map((l) => (
        <li
          class="reveal-up group relative grid grid-cols-12 gap-4 border-b border-rule py-8 transition-colors duration-500 dark:border-paper/10 sm:py-10 hover:bg-paper-soft dark:hover:bg-ink/40"
          data-lane
        >
          <span class="pointer-events-none absolute inset-x-0 bottom-0 h-px origin-left scale-x-0 bg-rust transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-x-100"></span>
          <div class="col-span-2 sm:col-span-1">
            <span class="font-mono text-xs uppercase tracking-[0.22em] text-rust transition-transform duration-500 group-hover:translate-x-1">/ {l.n}</span>
          </div>
          <div class="col-span-10 sm:col-span-5">
            <h3 class="font-editorial text-3xl text-ink dark:text-paper sm:text-4xl xl:text-5xl transition-colors duration-500 group-hover:text-rust">{l.title}</h3>
          </div>
          <div class="col-span-2 sm:col-span-2">
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.22em] text-ink-faint">{l.status}</span>
          </div>
          <div class="col-span-10 sm:col-span-4">
            <p class="text-base leading-relaxed text-ink-dim dark:text-paper/80 xl:text-lg">{l.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const eyebrow = document.querySelectorAll<HTMLElement>("[data-lanes-eyebrow]");
  const items = document.querySelectorAll<HTMLElement>("[data-lane]");

  if (!reduce) {
    if (eyebrow[0]) {
      gsap.fromTo(eyebrow, { opacity: 0, y: 28 }, {
        opacity: 1, y: 0, duration: 0.9, ease: "expo.out", immediateRender: false,
        scrollTrigger: { trigger: eyebrow[0], start: "top 88%" },
      });
    }
    items.forEach((el, i) => {
      gsap.fromTo(el, { opacity: 0, y: 28 }, {
        opacity: 1, y: 0, duration: 0.9, delay: i * 0.05, ease: "expo.out", immediateRender: false,
        scrollTrigger: { trigger: el, start: "top 90%" },
      });
    });
  }
</script>
